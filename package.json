{
  "name": "bingo-app",
  "private": true,
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.17.1",
    "picomatch": "^4.0.4",
    "http-proxy-agent": "^7.0.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
