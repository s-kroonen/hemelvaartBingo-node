{
  "info": {
    "name": "Bingo App API",
    "_postman_id": "bingo-api-collection",
    "description": "Full API collection for Bingo App backend (NestJS + Firebase Auth)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "matchId", "value": "" },
    { "key": "eventId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth (Firebase REST)",
      "item": [
        {
          "name": "Firebase Email/Password Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"returnSecureToken\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// Store Firebase ID token for backend usage",
                  "pm.collectionVariables.set('token', json.idToken);",
                  "pm.collectionVariables.set('userId', json.localId);",
                  "",
                  "console.log('Firebase login success');"
                ]
              }
            }
          ]
        },
        {
          "name": "Firebase Sign Up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebaseApiKey}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"returnSecureToken\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.collectionVariables.set('token', json.idToken);",
                  "pm.collectionVariables.set('userId', json.localId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Firebase Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "https://securetoken.googleapis.com/v1/token?key={{firebaseApiKey}}",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token" },
                { "key": "refresh_token", "value": "{{refreshToken}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.collectionVariables.set('token', json.id_token);",
                  "pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Firebase User Info",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:lookup?key={{firebaseApiKey}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout (Client-side only)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.unset('token');",
                  "pm.collectionVariables.unset('refreshToken');"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "Update Current Match",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/current-match",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matchId\": \"{{matchId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Matches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/matches/my"
          }
        }
      ]
    },

    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Add Role to User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}/role/remove",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"master\"\n}"
            }
          }
        },
        {
          "name": "Get All Matches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/admin/matches"
          }
        },
        {
          "name": "Create Match",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/matches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Match\",\n  \"startDate\": \"2026-04-01T00:00:00Z\",\n  \"endDate\": \"2026-04-30T23:59:59Z\"\n}"
            }
          }
        },
        {
          "name": "Assign Master",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/matches/{{matchId}}/master",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Match",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/admin/matches/{{matchId}}"
          }
        }
      ]
    },

    {
      "name": "Master",
      "item": [
        {
          "name": "Get My Master Matches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/master/matches"
          }
        },
        {
          "name": "Get Match Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/master/matches/{{matchId}}"
          }
        },
        {
          "name": "Update Match Name",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/master/matches/{{matchId}}/name",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Match Name\"\n}"
            }
          }
        },
        {
          "name": "Get Events",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/master/matches/{{matchId}}/events"
          }
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/master/matches/{{matchId}}/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Event\",\n  \"description\": \"Event description\"\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/master/matches/{{matchId}}/events/{{eventId}}"
          }
        }
      ]
    },

    {
      "name": "Public",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/matches/{{matchId}}/leaderboard"
          }
        }
      ]
    }
  ]
}